FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Install PyRosetta, JAX, PyTorch, BindCraft, BoltzGen, and PXdesign according
# to your licensed/internal distribution channels before building production
# images from this scaffold.
CMD ["python3", "--version"]
