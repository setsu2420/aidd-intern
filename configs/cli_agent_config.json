{
  "model_name": "${AIDD_INTERN_DEFAULT_MODEL_ID:-vllm/qwen3.6-35b-a3b}",
  "domain_pack": "aidd_binder",
  "save_sessions": true,
  "session_dataset_repo": "smolagents/aidd-intern-sessions",
  "share_traces": true,
  "personal_trace_repo_template": "{hf_user}/aidd-intern-sessions",
  "yolo_mode": false,
  "confirm_cpu_jobs": true,
  "auto_file_upload": true,
  "tool_runtime": "local",
  "messaging": {
    "enabled": false,
    "auto_event_types": ["approval_required", "error", "turn_complete"],
    "destinations": {}
  },
  "mcpServers": {
    "hf-mcp-server": {
      "transport": "http",
      "url": "https://hf.co/mcp"
    },
    "proteinmcp-bindcraft": {
      "transport": "stdio",
      "command": "bash",
      "args": [
        "${AIDD_INTERN_WORKDIR:-.}/scripts/run-proteinmcp-local.sh",
        "bindcraft_mcp"
      ],
      "cwd": "${AIDD_INTERN_WORKDIR:-.}",
      "timeout": 120
    },
    "proteinmcp-boltzgen": {
      "transport": "stdio",
      "command": "bash",
      "args": [
        "${AIDD_INTERN_WORKDIR:-.}/scripts/run-proteinmcp-local.sh",
        "boltzgen_mcp"
      ],
      "cwd": "${AIDD_INTERN_WORKDIR:-.}",
      "timeout": 120
    },
    "proteinmcp-pxdesign": {
      "transport": "stdio",
      "command": "bash",
      "args": [
        "${AIDD_INTERN_WORKDIR:-.}/scripts/run-proteinmcp-local.sh",
        "pxdesign_mcp"
      ],
      "cwd": "${AIDD_INTERN_WORKDIR:-.}",
      "timeout": 120
    }
  }
}
